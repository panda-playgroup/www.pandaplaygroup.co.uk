{
    "name": "www.pandaplaygroup.co.uk",
    "private": true,
    "scripts": {
        "start": "gatsby develop",
        "build": "gatsby build",
        "serve": "gatsby serve",
        "clean": "gatsby clean",
        "format": "prettier --write .",
        "check-format": "prettier --check .",
        "lint": "eslint .",
        "fix-lint": "eslint . --fix",
        "check-types": "npm run check-types:gatsby && npm run check-types:cypress",
        "check-types:gatsby": "tsc",
        "check-types:cypress": "tsc --project cypress/tsconfig.json",
        "test": "jest",
        "e2e": "cypress run",
        "perf": "lhci autorun",
        "check": "npm run lint && npm run check-format && npm run check-types && npm run test",
        "fc": "npm run fix-lint && npm run format && npm run check-types && npm run test",
        "bs": "npm run build && npm run serve",
        "cy": "cypress open",
        "prepare": "husky"
    },
    "dependencies": {
        "flowbite": "4.0.1",
        "flowbite-react": "0.12.17",
        "gatsby": "5.16.1",
        "gatsby-plugin-html-attributes": "1.0.5",
        "gatsby-plugin-image": "3.16.0",
        "gatsby-plugin-manifest": "5.16.0",
        "gatsby-plugin-remove-serviceworker": "1.0.0",
        "gatsby-plugin-sharp": "5.16.0",
        "gatsby-source-contentful": "8.17.0",
        "gatsby-transformer-sharp": "5.16.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "sharp": "0.34.5"
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@babel/preset-react": "7.28.5",
        "@babel/preset-typescript": "7.28.5",
        "@commitlint/cli": "20.5.0",
        "@commitlint/config-conventional": "20.5.0",
        "@lhci/cli": "0.15.1",
        "@tailwindcss/postcss": "4.2.4",
        "@testing-library/cypress": "10.1.0",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@tsconfig/cypress": "1.0.5",
        "@types/jest": "30.0.0",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "autoprefixer": "10.5.0",
        "babel-preset-gatsby": "3.16.0",
        "cypress": "15.14.1",
        "@typescript-eslint/eslint-plugin": "8.59.0",
        "@typescript-eslint/parser": "8.59.0",
        "eslint": "8.57.1",
        "eslint-config-prettier": "10.1.8",
