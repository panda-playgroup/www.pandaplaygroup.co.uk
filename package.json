        "gatsby-plugin-postcss": "6.16.0",
        "gatsby-plugin-tsconfig-paths": "1.0.6",
        "husky": "9.1.7",
        "jest": "30.3.0",
        "jest-environment-jsdom": "30.3.0",
        "jest-extended": "7.0.0",
        "lint-staged": "16.4.0",
        "postcss": "8.5.10",
        "prettier": "3.8.3",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3"
    },
